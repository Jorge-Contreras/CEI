@page "/login"
@attribute [AllowAnonymous]
@layout EmptyLayout
@inject NavigationManager NavigationManager

<PageTitle>Iniciar sesión</PageTitle>

<section class="login-shell">
    <div class="login-panel">
        <div class="login-heading">
            <p class="eyebrow">Corporativo Estrategia Integral</p>
            <h1>Ingreso al sistema</h1>
            <p>Administra expedientes, plazos y documentos con una sola vista operativa.</p>
        </div>

        @if (HasError)
        {
            <div class="alert alert-danger">Las credenciales no son válidas.</div>
        }

        <form method="post" action="/account/login" class="login-form">
            <input type="hidden" name="returnUrl" value="@ReturnUrl" />

            <div>
                <label class="form-label" for="email">Correo</label>
                <input class="form-control" id="email" name="email" autocomplete="username" required />
            </div>

            <div>
                <label class="form-label" for="password">Contraseña</label>
                <input class="form-control" id="password" name="password" type="password" autocomplete="current-password" required />
            </div>

            <label class="form-check">
                <input class="form-check-input" type="checkbox" name="rememberMe" />
                <span class="form-check-label">Mantener sesión</span>
            </label>

            <button class="btn btn-dark w-100" type="submit">Entrar</button>
        </form>

        <div class="login-help">
            <strong>Usuarios demo</strong>
            <p>principal@cei.local, admin@cei.local, assistant@cei.local, specialist@cei.local</p>
        </div>
    </div>
</section>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    public string? ErrorFlag { get; set; }

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrlQuery { get; set; }

    private bool HasError => ErrorFlag == "1";

    private string ReturnUrl => string.IsNullOrWhiteSpace(ReturnUrlQuery) ? "/" : ReturnUrlQuery!;
}
