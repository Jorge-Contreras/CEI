@if (Events.Count == 0)
{
    <div class="empty-state">
        <strong>Sin hitos registrados.</strong>
        <p>Agrega un evento procesal para iniciar la línea del tiempo.</p>
    </div>
}
else
{
    <div class="timeline">
        @foreach (var entry in Events.OrderBy(x => x.EventDate).ThenBy(x => x.Sequence))
        {
            <a class="timeline-node @(entry.Id == SelectedEventId ? "is-selected" : string.Empty)"
               href="#event-@entry.Id"
               @onclick="@(() => SelectedEventId = entry.Id)">
                <div class="timeline-marker"></div>
                <div class="timeline-card">
                    <div class="timeline-date">@entry.EventDate.ToString("dd MMM yyyy")</div>
                    <h4>@entry.Title</h4>
                    <p>@entry.EventTypeName</p>
                    @if (entry.LinkedDocumentCount > 0)
                    {
                        <small>@entry.LinkedDocumentCount documento(s) vinculado(s)</small>
                    }
                </div>
            </a>
        }
    </div>
}

@code {
    [Parameter]
    public IReadOnlyList<CaseEventDto> Events { get; set; } = [];

    private Guid? SelectedEventId { get; set; }
}
